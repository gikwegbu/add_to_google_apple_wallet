PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# ── DATABASE ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/wallet_db

# ── GOOGLE WALLET ────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_ISSUER_ID=your_google_issuer_id
GOOGLE_CLASS_ID=your_pass_class_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# ── APPLE WALLET ─────────────────────────────────────
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.wallet
APPLE_CERT_PATH=../apple/certs/passcertificate.pem
APPLE_KEY_PATH=../apple/certs/passkey.pem
APPLE_WWDR_PATH=../apple/certs/wwdr.pem
APPLE_CERT_PASSPHRASE=your_cert_passphrase
APPLE_APN_KEY_ID=YOUR_APN_KEY_ID
APPLE_APN_TEAM_ID=YOUR_APN_TEAM_ID
APPLE_APN_TOPIC=pass.com.yourcompany.wallet

# ── PASS ASSETS ──────────────────────────────────────
PASS_ORGANIZATION_NAME=Your Organization
PASS_DESCRIPTION=Electronic Ticket & Rewards Pass
PASS_LOGO_URL=https://your-cdn.com/logo.png

# ── REWARDS ──────────────────────────────────────────
REWARD_POINTS_PER_SCAN=10
REWARD_BASE_QUANTITY=10

# ── ADMIN AUTH ───────────────────────────────────────
ADMIN_JWT_SECRET=your_super_secret_key
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD_HASH=bcrypt_hashed_password

# ── FILE STORAGE (for ticket images) ─────────────────
S3_BUCKET_NAME=your-bucket
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
